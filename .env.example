# Root Docker Compose settings
COMPOSE_PROJECT_NAME=alib
APP_DOMAIN=example.com
CERTBOT_EMAIL=admin@example.com
CERTBOT_STAGING=0
NGINX_MODE=auto
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Cloudflare Tunnel. `make cloudflared-deploy` sets NGINX_MODE=cloudflared
# for the run. If using docker compose directly, set NGINX_MODE=cloudflared.
# Get the token from `cloudflared tunnel token <tunnel-name>` or Zero Trust.
CLOUDFLARED_TOKEN=

# Public URLs visible from the browser
PUBLIC_URL=https://example.com
VITE_API_BASE_URL=https://example.com
VITE_FRONTEND_BASE_URL=https://example.com
VITE_ALIB_API_URL=/api

# External SSO service
SSO_HTTP_URL=https://id.example.com
VITE_SSO_CLIENT_ID_URL=https://id.example.com/api

# Gateway
GATEWAY_DOMAIN=example.com
ALLOWED_REDIRECT_URLS=https://example.com
ALLOWED_CORS_ORIGINS=https://example.com
GRPC_TIMEOUT=24h
SWAGGER_ENABLED=true
SWAGGER_USER=
SWAGGER_PASSWORD=

# Semantic service
SEMANTIC_PORT=5104
LOG_LEVEL=DEBUG
LOGSTASH_HOST=
LOGSTASH_PORT=0

# Semantic database
SEMANTIC_DB_PORT=5432
SEMANTIC_DB_PUBLIC_PORT=15432
SEMANTIC_DB_USER=postgres
SEMANTIC_DB_PASSWORD=password
SEMANTIC_DB_NAME=semantic_db
SEMANTIC_DB_SSL_MODE=disable

# Search index and model
FAISS_INDEX_PATH=data/index/faiss_both.index
FAISS_DOC_IDS_PATH=data/index/doc_ids_both.npy
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_BATCH_SIZE=128
EMBEDDING_LORA_PATH=

# Ingestion / pipeline
OPENALEX_EMAIL=
PIPELINE_LOG_LEVEL=INFO
PIPELINE_OPENALEX_EN=1000000
PIPELINE_OPENALEX_RU=550000
PIPELINE_OPENALEX_CHUNK=50000
INGESTION_SCHEDULER_ENABLED=true
INGESTION_OPENALEX_ENABLED=false
INGESTION_OPENALEX_LIMIT=100
INGESTION_OPENALEX_INTERVAL_SECONDS=3600
INGESTION_OPENALEX_LANGUAGES=en,ru
INGESTION_WEIGHTED_RUNTIME_REQUIRED=false
